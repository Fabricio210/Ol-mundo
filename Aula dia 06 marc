def som(a,b): return a+b
def sub(a,b): return a-b
def mut(a,b): return a*b
def div(a,b): return a/b
def exp(a,b): return a**b
num1 = float(input("digite o número 1: ")); num2 = float(input("digite o número 2: ")); op = (input("Escolha a operação: (+,-,*,/,**): "))
if op == "+": print(som(num1,num2))
elif op == "-": print(sub(num1,num2))
elif op == "*": print(mut(num1,num2))
elif op == "/": print(div(num1,num2))
elif op == "*": print(exp(num1,num2))
else:
    print("Operação Mal concluida")
